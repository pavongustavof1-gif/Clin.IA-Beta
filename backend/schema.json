{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClinIA Medical Note Schema",
  "description": "SOAP-compliant medical note structure for Spanish language consultations",
  "type": "object",
  "properties": {
    "informacion_paciente": {
      "type": "object",
      "properties": {
        "nombre_del_paciente": {
          "type": "string",
          "description": "Full name of the patient"
        },
        "fecha_de_nacimiento": {
          "type": "string",
          "description": "Patient's date of birth (DD/MM/YYYY format preferred)"
        },
        "edad": {
          "type": "string",
          "description": "Patient's age"
        },
        "genero": {
          "type": "string",
          "description": "Patient's gender"
        },
        "numero_de_expediente": {
          "type": "string",
          "description": "Medical record number if mentioned"
        },
        "numero_expediente": {
          "type": "string",
          "description": "Número de expediente clínico asignado por el consultorio"
        },
        "curp": {
          "type": "string",
          "description": "Clave Única de Registro de Población — 18 caracteres alfanuméricos. No autogenerar."
        }
      }
    },
    "subjetivo": {
      "type": "object",
      "description": "Subjective section - patient's complaints and symptoms",
      "properties": {
        "motivo_de_consulta": {
          "type": "string",
          "description": "Chief complaint - reason for visit"
        },
        "sintomas": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of symptoms described by patient"
        },
        "historia_de_enfermedad_actual": {
          "type": "string",
          "description": "History of present illness"
        },
        "duracion_sintomas": {
          "type": "string",
          "description": "How long symptoms have been present"
        }
      }
    },
    "objetivo": {
      "type": "object",
      "description": "Objective section - physical examination findings",
      "properties": {
        "signos_vitales": {
          "type": "object",
          "properties": {
            "presion_arterial": {"type": "string"},
            "frecuencia_cardiaca": {"type": "string"},
            "temperatura": {"type": "string"},
            "frecuencia_respiratoria": {"type": "string"},
            "saturacion_oxigeno": {"type": "string"},
            "peso": {
              "type": "string",
              "description": "Peso del paciente en kilogramos"
            },
            "talla": {
              "type": "string",
              "description": "Talla del paciente en metros o centímetros"
            }
          }
        },
        "habitus_exterior": {
          "type": "string",
          "description": "Descripción general del aspecto del paciente: edad aparente, estado de consciencia, orientación, estado nutricional, marcha, actitud"
        },
        "examen_fisico": {
          "type": "string",
          "description": "Physical examination findings"
        },
        "hallazgos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Notable findings from examination"
        }
      }
    },
    "evaluacion": {
      "type": "object",
      "description": "Assessment section - diagnosis",
      "properties": {
        "diagnostico": {
          "type": "string",
          "description": "Primary diagnosis"
        },
        "diagnosticos_adicionales": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional or differential diagnoses"
        },
        "impresion_clinica": {
          "type": "string",
          "description": "Clinical impression"
        },
        "pronostico": {
          "type": "string",
          "description": "Pronóstico del médico sobre la evolución esperada del paciente"
        }
      }
    },
    "plan": {
      "type": "object",
      "description": "Plan section - treatment and follow-up",
      "properties": {
        "tratamiento": {
          "type": "string",
          "description": "Treatment plan"
        },
        "medicamentos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nombre": {"type": "string"},
              "dosis": {"type": "string"},
              "frecuencia": {"type": "string"},
              "duracion": {"type": "string"}
            }
          },
          "description": "Prescribed medications"
        },
        "recomendaciones": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Medical recommendations and instructions"
        },
        "estudios_solicitados": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Requested tests or studies"
        },
        "seguimiento": {
          "type": "string",
          "description": "Follow-up instructions"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "fecha_consulta": {
          "type": "string",
          "description": "Date of consultation"
        },
        "medico": {
          "type": "string",
          "description": "Attending physician name"
        },
        "duracion_consulta": {
          "type": "string",
          "description": "Duration of consultation"
        },
        "fecha_hora_consulta": {
          "type": "string",
          "description": "Exact date and time the consultation was recorded, injected from client device"
        }
      }
    },
    "actualizacion_antecedentes": {
      "type": "object",
      "description": "Detects new hereditary, family, or personal medical history mentioned during the consultation",
      "properties": {
        "detectado": {
          "type": "boolean",
          "description": "True if new background information was mentioned"
        },
        "contenido": {
          "type": "string",
          "description": "Description of the new antecedent mentioned, if detected"
        }
      }
    }
  },
  "required": ["informacion_paciente"]
}
